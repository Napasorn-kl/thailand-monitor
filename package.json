{
  "name": "thailand-monitor",
  "version": "1.0.0",
  "description": "Thailand Macro-Economic Intelligence Dashboard",
  "main": "main.js",
  "scripts": {
    "dev": "vite",
    "build:renderer": "vite build",
    "start": "electron .",
    "build": "electron-builder --mac",
    "build:dmg": "electron-builder --mac dmg"
  },
  "build": {
    "appId": "com.thailandmonitor.app",
    "productName": "Thailand Monitor",
    "copyright": "Copyright © 2026 Thailand Monitor",
    "mac": {
      "category": "public.app-category.finance",
      "icon": "build/icon.icns",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "darkModeSupport": true,
      "minimumSystemVersion": "11.0"
    },
    "dmg": {
      "title": "Thailand Monitor",
      "background": "build/dmg-background.png",
      "window": {
        "width": 540,
        "height": 380
      },
      "contents": [
        {
          "x": 150,
          "y": 185,
          "type": "file"
        },
        {
          "x": 390,
          "y": 185,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "files": [
      "main.js",
      "preload.js",
      "dist/**/*",
      "build/**/*"
    ],
    "extraMetadata": {
      "main": "main.js"
    }
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.1",
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8",
    "vite": "^8.0.3"
  },
  "dependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@tremor/react": "^3.18.7",
    "autoprefixer": "^10.4.27",
    "lucide-react": "^1.7.0",
    "postcss": "^8.5.8",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^3.8.1",
    "tailwindcss": "^4.2.2"
  }
}
